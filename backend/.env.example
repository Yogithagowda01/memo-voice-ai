# MemoVoice AI Backend Configuration

# ═══════════════════════════════════════════════════════════════
# REQUIRED: Google Gemini API Key
# Get your free key at: https://aistudio.google.com/app/apikey
# ═══════════════════════════════════════════════════════════════
GEMINI_API_KEY=your_api_key_here

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Specific Gemini Model to Use
# Available models depend on your API key and region
# Common options:
#   - gemini-2.0-flash (newest, fast)
#   - gemini-1.5-flash (most compatible)
#   - gemini-1.5-pro (most capable)
# If not set, the server will auto-detect the best available model
# ═══════════════════════════════════════════════════════════════
GEMINI_MODEL=gemini-1.5-flash

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Server Port
# Default: 5000
# ═══════════════════════════════════════════════════════════════
PORT=5000

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Environment
# Options: development, production
# Default: development
# ═══════════════════════════════════════════════════════════════
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Frontend URL for CORS
# Add your frontend domain/URL here to allow cross-origin requests
# Example: http://localhost:3000
# Default: http://localhost:3000 (included by default)
# ═══════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:3000
